# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.pytest_cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
__pycache__/
*.py[cod]
.venv/
venv*/
/python-backend/venv-chatbot/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local credentials and service-account exports
*service-account*.json
secrets/
.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local development and agent tooling
/.agents/
/.codex/
/.impeccable/
/.run/
/.vscode/
/skills-lock.json
