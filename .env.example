# Direct Google Identity Services client ID from Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Canonical production origin, without a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public contact shown in privacy, terms, and support links
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_LEGAL_JURISDICTION=

# Neon pooled PostgreSQL connection string. Keep this server-only.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Gemini
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Vapi browser-safe public configuration
NEXT_PUBLIC_VAPI_WEB_TOKEN=
NEXT_PUBLIC_VAPI_WORKFLOW_ID=

# Text interview coach
PYTHON_API_URL=http://localhost:8001
# Long random secret shared only by the Next.js and Python services.
INTERNAL_SERVICE_KEY=
# Set to production on the deployed Python service.
ENVIRONMENT=development

# Optional OpenTelemetry exporter used by the hosting/observability provider.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
# Comma-separated browser origins for direct backend diagnostics.
BACKEND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
