{
  "name": "prepora",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "concurrently -n next,python -c cyan,yellow \"next dev --turbopack\" \"cd python-backend && uvicorn main:app --port 8001 --reload\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "validate:production": "node scripts/validate-production-env.mjs",
    "db:migrate": "node scripts/migrate-db.mjs",
    "db:check": "node scripts/check-db.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^4.1.3",
    "@opentelemetry/api-logs": "^0.221.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.1",
    "@smastrom/react-rating": "^1.5.0",
    "@vapi-ai/web": "^2.4.0",
    "@vercel/otel": "^2.1.3",
    "canvg": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "google-auth-library": "^10.9.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.482.0",
    "next": "^15.5.21",
    "next-nprogress-bar": "^2.3.12",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "sanitize-html": "^2.17.6",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.21",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "jws": "^3.2.3",
    "postcss": "^8.5.10",
    "sharp": "^0.35.0",
    "uuid": "^11.1.1"
  }
}
